#include "io.h"
#include <string.h>
#include <ncurses.h>

bool ifspace = 0 ; 
char errorbuffer[100];
uint32_t newline_char_count = 0;

bool ListenKeys(int character, uint32_t *cury, uint32_t *curx, Text** T, Dynamic_array* DA, char *filename) {
    char c = (char) character;
    int max_y, max_x;
    getmaxyx(stdscr, max_y, max_x);

    switch(character) {
        case is_ctrl('e'):
            return false;

        case is_ctrl('w'):
            SaveFile(filename, T);
            break;

        case KEY_UP:
            if (*cury > 0) {
                (*cury)--;
                *curx = get_line_length(*T, *cury);
                if (*curx > max_x - 1) *curx = max_x - 1;
                update_cursor_pos(T, *cury, *curx);
            }
            break;
            
        case KEY_DOWN:
            if (*cury < get_total_lines(*T) - 1) {
                (*cury)++;
                *curx = get_line_length(*T, *cury);
                if (*curx > max_x - 1) *curx = max_x - 1;
                update_cursor_pos(T, *cury, *curx);
            }
            break;

        case KEY_LEFT:
            if (*curx > 0) {
                (*curx)--;
                (*T)->gb->cursor_pos--;
            } else if (*cury > 0) {
                (*cury)--;
                *curx = get_line_length(*T, *cury);
                update_cursor_pos(T, *cury, *curx);
            }
            break;

        case KEY_RIGHT:
            if (*curx < get_line_length(*T, *cury)) {
                (*curx)++;
                (*T)->gb->cursor_pos++;
            } else if (*cury < get_total_lines(*T) - 1) {
                (*cury)++;
                *curx = 0;
                update_cursor_pos(T, *cury, *curx);
            }
            break;

        case 10: // Enter key
            InsertStringGB((*T)->gb, "\n", (*T)->gb->cursor_pos);
            (*cury)++;
            *curx = 0;
            update_cursor_pos(T, *cury, *curx);
            break;

        case KEY_BACKSPACE:
            if (*curx > 0) {
                (*curx)--;
                DeleteStringGB((*T)->gb, (*T)->gb->cursor_pos - 1, 1);
                (*T)->gb->cursor_pos--;
            } else if (*cury > 0) {
                (*cury)--;
                *curx = get_line_length(*T, *cury);
                DeleteStringGB((*T)->gb, (*T)->gb->cursor_pos - 1, 1);
                update_cursor_pos(T, *cury, *curx);
            }
            break;

        default:
                InsertStringGB((*T)->gb, &c, (*T)->gb->cursor_pos);
                (*curx)++;
                if (*curx >= max_x) {
                    (*cury)++;
                    *curx = 0;
                }
            break;
    }

    move(*cury, *curx);
    return true;
}

uint32_t get_line_length(Text* T, uint32_t line_number) {
    uint32_t length = 0;
    uint32_t current_line = 0;
    uint32_t i = 0;

    while (i < T->gb->buffer_size && current_line < line_number) {
        if (T->gb->buffer[i] == '\n') {
            current_line++;
        }
        i++;
    }

    while (i < T->gb->buffer_size && T->gb->buffer[i] != '\n') {
        if (T->gb->buffer[i] != GAP_CHARACTER) {
            length++;
        }
        i++;
    }

    return length;
}

uint32_t get_total_lines(Text* T) {
    uint32_t lines = 1;
    for (uint32_t i = 0; i < T->gb->buffer_size; i++) {
        if (T->gb->buffer[i] == '\n') {
            lines++;
        }
    }
    return lines;
}

void update_cursor_pos(Text** T, uint32_t cury, uint32_t curx) {
    uint32_t pos = 0;
    uint32_t current_line = 0;

    while (current_line < cury && pos < (*T)->gb->buffer_size) {
        if ((*T)->gb->buffer[pos] == '\n') {
            current_line++;
        }
        pos++;
    }

    pos += curx;
    (*T)->gb->cursor_pos = pos;
}

bool LoadFile(char * filename , Text** T) {
  FILE *file;
  int filesize;

  file = fopen(filename, "rb");


  if (!file) {
	sprintf(errorbuffer,"Could not open file %s\n", filename);
	perrorfile(errorbuffer);
    return false;
  }

  // Seek to the end of the file
  fseek(file, 0, SEEK_END);

  filesize = ftell(file);

  fclose(file);

  *T = InitText(filesize);
  file = fopen(filename, "r");

  if (!file) {
	sprintf(errorbuffer,"Could not open file %s\n", filename);
	perrorfile(errorbuffer);
    return false;
  }

  int cursor_pos = (*T)->gb->gap_start;
  char *temp = malloc(sizeof(char) * filesize);
  while (fgets(temp, sizeof(temp), file)) {
    InsertStringGB((*T)->gb, temp, cursor_pos);
    cursor_pos += strlen(temp);
  }
    free(temp); 
  return true;
}





bool SaveFile(char *filename,Text** T) {
  FILE *file = fopen(filename, "w");

  if (file == NULL)
    return 1;

  // Write the text before the gap
  for (int i = 0; i < (*T)->gb->gap_start; i++) {
    if ((*T)->gb->buffer[i] != GAP_CHARACTER) {
      fputc((*T)->gb->buffer[i], file);
    }
  }

  // Write the text after the gap
  for (int i = (*T)->gb->gap_end; i < (int)(*T)->gb->buffer_size; i++) {
    if ((*T)->gb->buffer[i] != GAP_CHARACTER) {
      fputc((*T)->gb->buffer[i], file);
    }
  }

  fclose(file);
  return 0; 
}
	
uint32_t index_of_newline(Dynamic_array* DA, int num){
	/*
		The index in the nth no of \n character while the respective number is the index pos
	 */
	return DA->aptr[num];
}

