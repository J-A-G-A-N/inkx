#include "render_txt.h"
#include <ncurses.h>

void RenderTextT(Text *T) {
    clear(); // Clear the screen
    int x = 0, y = 0;
    int max_y, max_x;
    getmaxyx(stdscr, max_y, max_x);

    for (int i = 0; i < T->gb->buffer_size; i++) {
        if (T->gb->buffer[i] != GAP_CHARACTER) {
            if (x >= max_x) {
                y++;
                x = 0;
                if (y >= max_y) break; // Stop rendering if we've filled the screen
            }
            if (y < max_y) {
                mvaddch(y, x, T->gb->buffer[i]);
                x++;
            }
        }
        if (T->gb->buffer[i] == '\n') {
            y++;
            x = 0;
            if (y >= max_y) break; // Stop rendering if we've filled the screen
        }
    }
    refresh();
}
